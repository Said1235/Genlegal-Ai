# Which GenLayer network the app talks to. One of:
#   studionet       - hosted, gasless, no Docker needed (default, easiest for Vercel)
#   localnet        - your own `genlayer up` node on http://127.0.0.1:4000/api
#   testnetAsimov   - needs a funded account: https://testnet-faucet.genlayer.foundation/
#   testnetBradbury - needs a funded account: https://testnet-faucet.genlayer.foundation/
NEXT_PUBLIC_GENLAYER_NETWORK=studionet

# Optional: override the chain's built-in RPC URL (useful if your local
# `genlayer up` node runs on a non-default port). Leave unset otherwise.
# NEXT_PUBLIC_GENLAYER_RPC_URL=http://127.0.0.1:4000/api

# Address of the deployed LegalContractAnalyzer Intelligent Contract.
# Filled in by `genlayer deploy` / deploy/deployScript.ts - see README.md.
NEXT_PUBLIC_CONTRACT_ADDRESS=
